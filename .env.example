# Ollamaduct Configuration

# Required: Ollama URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Optional: API Key for gateway authentication
# If not set, gateway will not be secured
API_KEY=your-secure-api-key-here

# Optional: Default model to use (default: llama2)
DEFAULT_MODEL=llama2

# Optional: Ollama API Key (if required by your Ollama instance)
# OLLAMA_KEY=
